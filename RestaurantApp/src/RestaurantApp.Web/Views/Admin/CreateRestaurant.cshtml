@model RestaurantApp.Core.Entities.Restaurant
@{
    ViewData["Title"] = "Nouveau Restaurant"; Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-plus-circle"></i> Nouveau Restaurant</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="CreateRestaurant" method="post">
                    @Html.AntiForgeryToken()
                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                    {
                        <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
                    }

                    <div class="mb-3">
                        <label asp-for="Nom" class="form-label fw-semibold"></label>
                        <input asp-for="Nom" class="form-control" />
                        <span asp-validation-for="Nom" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Adresse" class="form-label fw-semibold"></label>
                        <input asp-for="Adresse" class="form-control" />
                        <span asp-validation-for="Adresse" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Type" class="form-label fw-semibold"></label>
                        <select asp-for="Type" class="form-select"
                                asp-items="Html.GetEnumSelectList<RestaurantApp.Core.Enums.TypeRestaurant>()">
                        </select>
                        <span asp-validation-for="Type" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Telephone" class="form-label fw-semibold"></label>
                        <input asp-for="Telephone" class="form-control" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-fill">
                            <i class="bi bi-save"></i> Enregistrer
                        </button>
                        <a asp-action="Restaurants" class="btn btn-outline-secondary">
                            Annuler
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}