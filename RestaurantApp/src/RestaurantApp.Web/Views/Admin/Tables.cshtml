@model List<RestaurantApp.Core.Entities.TableRestaurant>
@{
    ViewData["Title"] = "Gestion Tables"; Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4><i class="bi bi-table"></i> Tables</h4>
    <a asp-action="CreateTable" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Ajouter
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Numéro</th>
                    <th>Restaurant</th>
                    <th>Capacité</th>
                    <th>Disponible</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model)
                {
                    <tr>
                        <td>@t.Id</td>
                        <td><strong>Table @t.Numero</strong></td>
                        <td>@t.Restaurant?.Nom</td>
                        <td><i class="bi bi-people"></i> @t.Capacite pers.</td>
                        <td>
                            @if (t.Disponible)
                            {
                                <span class="badge bg-success">Disponible</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Occupée</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1 align-items-center">
                                <button type="button" class="btn btn-sm btn-outline-danger"
                                        onclick="showConfirm(this, @t.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                                <span class="confirm-zone d-none" id="confirm-@t.Id">
                                    <span class="text-danger small fw-semibold me-1">Supprimer ?</span>
                                    <form asp-action="DeleteTable" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@t.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm">Oui</button>
                                    </form>
                                    <button type="button" class="btn btn-secondary btn-sm"
                                            onclick="hideConfirm(@t.Id)">
                                        Non
                                    </button>
                                </span>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function showConfirm(btn, id) {
            document.querySelectorAll('.confirm-zone').forEach(z => z.classList.add('d-none'));
            document.querySelectorAll('.btn-outline-danger').forEach(b => b.classList.remove('d-none'));
            document.getElementById('confirm-' + id).classList.remove('d-none');
            btn.classList.add('d-none');
        }
        function hideConfirm(id) {
            document.getElementById('confirm-' + id).classList.add('d-none');
            document.querySelectorAll('.btn-outline-danger').forEach(b => b.classList.remove('d-none'));
        }
    </script>
}