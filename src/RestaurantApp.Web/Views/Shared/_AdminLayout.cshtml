<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        body { background: #f8f9fa; }
        .sidebar {
            width: 240px; min-height: 100vh;
            background: #1a1a2e; position: fixed; top: 0; left: 0;
            padding-top: 1rem; z-index: 100;
        }
        .sidebar .brand {
            color: #fff; font-size: 1.1rem; font-weight: 700;
            padding: 1rem 1.5rem 1.5rem;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        .sidebar .nav-link {
            color: rgba(255,255,255,0.7); padding: .65rem 1.5rem;
            border-radius: 0; transition: all .2s;
        }
        .sidebar .nav-link:hover,
        .sidebar .nav-link.active {
            color: #fff; background: rgba(255,255,255,0.1);
            border-left: 3px solid #667eea;
        }
        .sidebar .nav-link i { width: 20px; }
        .main-content { margin-left: 240px; padding: 2rem; }
        .topbar {
            background: #fff; border-bottom: 1px solid #e2e8f0;
            padding: .75rem 2rem; margin: -2rem -2rem 2rem;
            display: flex; justify-content: space-between; align-items: center;
        }
        .stat-card {
            border-radius: 12px; padding: 1.25rem;
            display: flex; flex-direction: column; gap: 4px;
        }
        .stat-icon { font-size: 1.8rem; opacity: .8; }
        .stat-value { font-size: 2rem; font-weight: 700; line-height: 1; }
        .stat-label { font-size: .8rem; opacity: .85; }
    </style>
</head>
<body>

<!-- Sidebar -->
<div class="sidebar">
    <div class="brand">🍽 Admin Panel</div>
    <nav class="nav flex-column mt-2">
        @{
        var current = ViewContext.RouteData.Values["action"]?.ToString();
        }

        <a asp-action="Dashboard" class="nav-link @(current == "Dashboard" ? "active" : "")">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>
        <a asp-action="Restaurants" class="nav-link @(current == "Restaurants" ? "active" : "")">
            <i class="bi bi-shop"></i> Restaurants
        </a>
        <a asp-action="Employes" class="nav-link @(current == "Employes" ? "active" : "")">
            <i class="bi bi-person-badge"></i> Employés
        </a>
        <a asp-action="Tables" class="nav-link @(current == "Tables" ? "active" : "")">
            <i class="bi bi-table"></i> Tables
        </a>
        <a asp-action="Menus" class="nav-link @(current == "Menus" ? "active" : "")">
            <i class="bi bi-menu-button"></i> Menus
        </a>
        <a asp-action="Reservations" class="nav-link @(current == "Reservations" ? "active" : "")">
            <i class="bi bi-calendar-check"></i> Réservations
        </a>
        <a asp-action="Clients" class="nav-link @(current == "Clients" ? "active" : "")">
            <i class="bi bi-people"></i> Clients
        </a>
    </nav>
</div>

<!-- Main -->
<div class="main-content">
    <div class="topbar">
        <h6 class="mb-0 fw-semibold text-muted">@ViewData["Title"]</h6>
        <form asp-controller="Account" asp-action="Logout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-outline-danger">
                <i class="bi bi-box-arrow-right"></i> Déconnexion
            </button>
        </form>
    </div>
    @RenderBody()
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>