@model List<RestaurantApp.Core.Entities.Reservation>
@{
    ViewData["Title"] = "Mes Réservations";
}

<h2 class="mb-4"><i class="bi bi-calendar-check"></i> Mes Réservations</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-circle"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> Vous n'avez aucune réservation.
        <a asp-controller="Restaurant" asp-action="Index" class="alert-link">
            Voir les restaurants
        </a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Restaurant</th>
                    <th>Date</th>
                    <th>Table</th>
                    <th>Personnes</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td><strong>@r.Restaurant?.Nom</strong></td>
                        <td>@r.Date.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>Table @r.TableRestaurant?.Numero</td>
                        <td><i class="bi bi-people"></i> @r.NbPersonnes</td>
                        <td>
                            @if (r.StatutReservation)
                            {
                                <span class="badge bg-success">Confirmée</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Annulée</span>
                            }
                        </td>
                        <td>
                            @if (r.StatutReservation && r.Date > DateTime.Now)
                            {
                                <form asp-action="Annuler" asp-route-id="@r.Id"
                                      method="post"
                                      onsubmit="return confirm('Annuler cette réservation ?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        <i class="bi bi-x-circle"></i> Annuler
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}