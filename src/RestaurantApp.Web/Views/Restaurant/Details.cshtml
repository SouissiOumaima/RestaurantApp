@model RestaurantApp.Core.Entities.Restaurant
@{ ViewData["Title"] = Model.Nom; }

<div class="row">
  <div class="col-md-8">

    <!-- En-tête restaurant -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-start mb-3">
          <div>
            <h2 class="fw-bold mb-1">@Model.Nom</h2>
            <span class="badge bg-primary fs-6">@Model.Type</span>
          </div>
          <div class="text-end">
            @for (int i = 1; i <= 5; i++)
            {
              <i class="bi @(i <= Model.NoteGlobale ? "bi-star-fill text-warning" : "bi-star text-muted")"></i>
            }
            <div class="text-muted small">@Model.NoteGlobale.ToString("0.0") / 5</div>
          </div>
        </div>

        <p class="text-muted mb-1">
          <i class="bi bi-geo-alt-fill text-danger"></i> @Model.Adresse
        </p>
        @if (Model.Telephone != null)
        {
          <p class="text-muted mb-0">
            <i class="bi bi-telephone-fill text-success"></i> @Model.Telephone
          </p>
        }
      </div>
    </div>

    <!-- Menus et Plats -->
    @if (Model.Menus != null && Model.Menus.Any())
    {
      <h4 class="fw-bold mb-3"><i class="bi bi-menu-button-wide"></i> Nos Menus</h4>
      @foreach (var menu in Model.Menus)
      {
        <div class="card border-0 shadow-sm mb-3">
          <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-semibold">@menu.Libelle</h5>
            <span class="badge bg-success fs-6">@menu.PrixTotal.ToString("0.00") DT</span>
          </div>
          @if (menu.Plats != null && menu.Plats.Any())
          {
            <div class="card-body p-0">
              <table class="table table-hover mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Plat</th>
                    <th>Catégorie</th>
                    <th class="text-end">Prix</th>
                    <th class="text-center">Dispo</th>
                  </tr>
                </thead>
                <tbody>
                  @foreach (var plat in menu.Plats)
                  {
                    <tr>
                      <td><strong>@plat.Nom</strong>
                        @if (!string.IsNullOrEmpty(plat.Description))
                        {
                          <br/><small class="text-muted">@plat.Description</small>
                        }
                      </td>
                      <td><span class="badge bg-secondary">@plat.Categorie?.Libelle</span></td>
                      <td class="text-end">@plat.Prix.ToString("0.00") DT</td>
                      <td class="text-center">
                        @if (plat.Disponible)
                        {
                          <i class="bi bi-check-circle-fill text-success"></i>
                        }
                        else
                        {
                          <i class="bi bi-x-circle-fill text-danger"></i>
                        }
                      </td>
                    </tr>
                  }
                </tbody>
              </table>
            </div>
          }
        </div>
      }
    }

    <!-- Avis -->
    @if (Model.Avis != null && Model.Avis.Any())
    {
      <h4 class="fw-bold mb-3 mt-4"><i class="bi bi-chat-quote"></i> Avis clients</h4>
      @foreach (var avis in Model.Avis)
      {
        <div class="card border-0 shadow-sm mb-2">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-1">
              <strong>@avis.Client?.Nom @avis.Client?.Prenom</strong>
              <div>
                @for (int i = 1; i <= 5; i++)
                {
                  <i class="bi @(i <= avis.Note ? "bi-star-fill text-warning" : "bi-star text-muted")"
                     style="font-size:12px"></i>
                }
              </div>
            </div>
            @if (!string.IsNullOrEmpty(avis.Commentaire))
            {
              <p class="text-muted small mb-0">@avis.Commentaire</p>
            }
            <small class="text-muted">@avis.DateAvis.ToString("dd/MM/yyyy")</small>
          </div>
        </div>
      }
    }

  </div>

  <!-- Sidebar -->
  <div class="col-md-4">

    <!-- Tables disponibles -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white fw-semibold">
        <i class="bi bi-table"></i> Tables disponibles
      </div>
      <div class="card-body">
        @if (Model.Tables != null && Model.Tables.Any(t => t.Disponible))
        {
          @foreach (var table in Model.Tables.Where(t => t.Disponible))
          {
            <div class="d-flex justify-content-between align-items-center py-1 border-bottom">
              <span><i class="bi bi-circle-fill text-success" style="font-size:8px"></i>
                Table @table.Numero</span>
              <span class="badge bg-light text-dark">
                <i class="bi bi-people"></i> @table.Capacite pers.
              </span>
            </div>
          }
        }
        else
        {
          <p class="text-muted small mb-0">Aucune table disponible actuellement.</p>
        }
      </div>
    </div>

    <!-- Bouton réserver -->
    @if (User.Identity?.IsAuthenticated == true)
    {
      <a asp-controller="Reservation"
         asp-action="Create"
         asp-route-restaurantId="@Model.Id"
         class="btn btn-success w-100 mb-3 py-2">
        <i class="bi bi-calendar-plus"></i> Réserver une table
      </a>
    }
    else
    {
      <a asp-controller="Account" asp-action="Login"
         class="btn btn-outline-success w-100 mb-3 py-2">
        <i class="bi bi-box-arrow-in-right"></i> Connectez-vous pour réserver
      </a>
    }

    <a asp-action="Index" class="btn btn-outline-secondary w-100">
      <i class="bi bi-arrow-left"></i> Retour à la liste
    </a>

  </div>
</div>