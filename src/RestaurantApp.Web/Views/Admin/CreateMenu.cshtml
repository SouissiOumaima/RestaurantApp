@{
    ViewData["Title"] = "Nouveau Menu"; Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="bi bi-plus-circle"></i> Nouveau Menu</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="CreateMenu" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Restaurant</label>
                        <select name="RestaurantId" class="form-select"
                                asp-items="ViewBag.Restaurants">
                            <option value="">-- Choisir --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Libellé du menu</label>
                        <input name="Libelle" class="form-control"
                               placeholder="Ex: Menu Classique" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea name="Description" class="form-control" rows="2"
                                  placeholder="Description du menu..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Prix total (DT)</label>
                        <input name="PrixTotal" type="number" step="0.01" min="0"
                               class="form-control" required />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning flex-fill">
                            <i class="bi bi-save"></i> Enregistrer
                        </button>
                        <a asp-action="Menus" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>