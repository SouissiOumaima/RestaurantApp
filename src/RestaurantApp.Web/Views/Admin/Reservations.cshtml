@model List<RestaurantApp.Core.Entities.Reservation>
@{
    ViewData["Title"] = "Gestion Réservations"; Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4><i class="bi bi-calendar-check"></i> Réservations</h4>
    <span class="badge bg-primary fs-6">@Model.Count au total</span>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Client</th>
                    <th>Restaurant</th>
                    <th>Date</th>
                    <th>Table</th>
                    <th>Personnes</th>
                    <th>Statut</th>
                    <th>Notes</th>        <!-- ← colonne ajoutée -->
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>@r.Id</td>
                        <td>@r.Client?.Nom @r.Client?.Prenom</td>
                        <td>@r.Restaurant?.Nom</td>
                        <td>@r.Date.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>Table @r.TableRestaurant?.Numero</td>
                        <td>@r.NbPersonnes pers.</td>
                        <td>
                            <span class="badge @(r.StatutReservation ? "bg-success" : "bg-secondary")">
                                @(r.StatutReservation ? "Confirmée" : "Annulée")
                            </span>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(r.Notes))
                            {
                                <span class="badge bg-light text-dark border"
                                      title="@r.Notes"
                                      data-bs-toggle="tooltip">
                                    <i class="bi bi-chat-left-text"></i>
                                    @(r.Notes.Length > 25 ? r.Notes.Substring(0, 25) + "..." : r.Notes)
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1 align-items-center">
                                <button type="button" class="btn btn-sm btn-outline-danger"
                                        onclick="showConfirm(this, @r.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                                <span class="confirm-zone d-none" id="confirm-@r.Id">
                                    <span class="text-danger small fw-semibold me-1">Supprimer ?</span>
                                    <form asp-action="DeleteReservation" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@r.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm">Oui</button>
                                    </form>
                                    <button type="button" class="btn btn-secondary btn-sm"
                                            onclick="hideConfirm(@r.Id)">
                                        Non
                                    </button>
                                </span>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        // Activer les tooltips Bootstrap pour afficher la note complète au survol
        document.querySelectorAll('[data-bs-toggle="tooltip"]')
                .forEach(el => new bootstrap.Tooltip(el));

        function showConfirm(btn, id) {
            document.querySelectorAll('.confirm-zone').forEach(z => z.classList.add('d-none'));
            document.querySelectorAll('.btn-outline-danger').forEach(b => b.classList.remove('d-none'));
            document.getElementById('confirm-' + id).classList.remove('d-none');
            btn.classList.add('d-none');
        }
        function hideConfirm(id) {
            document.getElementById('confirm-' + id).classList.add('d-none');
            document.querySelectorAll('.btn-outline-danger').forEach(b => b.classList.remove('d-none'));
        }
    </script>
}