@model List<RestaurantApp.Core.Entities.Restaurant>
@{
    ViewData["Title"] = "Gestion Restaurants"; Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert border-0 shadow-sm" role="alert"
         style="background:#fff8f0; border-left:4px solid #f59e0b !important; border-radius:10px;">
        <div class="d-flex align-items-start gap-3">
            <div style="font-size:1.5rem">⚠</div>
            <div>
                <div class="fw-semibold mb-1" style="color:#92400e">Action bloquée</div>
                <div style="color:#78350f; font-size:0.9rem">@TempData["Error"]</div>
                <div class="mt-2" style="font-size:0.82rem; color:#a16207">
                    Supprimez d'abord les données liées depuis le menu Admin, puis réessayez.
                </div>
            </div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4><i class="bi bi-shop"></i> Restaurants</h4>
    <a asp-action="CreateRestaurant" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Ajouter
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Nom</th>
                    <th>Type</th>
                    <th>Adresse</th>
                    <th>Note</th>
                    <th>Tables</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>@r.Id</td>
                        <td><strong>@r.Nom</strong></td>
                        <td><span class="badge bg-primary">@r.Type</span></td>
                        <td class="text-muted small">@r.Adresse</td>
                        <td>
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="bi @(i <= r.NoteGlobale
                                ? "bi-star-fill text-warning"
                                : "bi-star text-muted")" style="font-size:12px"></i>
                        }
                    </td>
                    <td>@r.Tables.Count</td>
                    <td>
                        <div class="d-flex gap-1 align-items-center">
                            <a asp-action="EditRestaurant" asp-route-id="@r.Id"
                                   class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil"></i>
                            </a>

                            <!-- Bouton qui affiche la confirmation inline -->
                            <button type="button" class="btn btn-sm btn-outline-danger"
                                    onclick="showConfirm(this, @r.Id, '@r.Nom.Replace("'", "\\'")' )">
                                <i class="bi bi-trash"></i>
                            </button>

                            <!-- Zone de confirmation cachée -->
                            <span class="confirm-zone d-none" id="confirm-@r.Id">
                                <span class="text-danger small fw-semibold me-1">Supprimer ?</span>
                                <form asp-action="DeleteRestaurant" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@r.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm">Oui</button>
                                </form>
                                <button type="button" class="btn btn-secondary btn-sm"
                                        onclick="hideConfirm(@r.Id)">
                                    Non
                                </button>
                            </span>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
</div>
@section Scripts {
    <script>
        function showConfirm(btn, id, nom) {
            // Cacher toutes les autres confirmations ouvertes
            document.querySelectorAll('.confirm-zone').forEach(z => z.classList.add('d-none'));

            // Afficher celle-ci
            document.getElementById('confirm-' + id).classList.remove('d-none');

            // Cacher le bouton poubelle
            btn.classList.add('d-none');
        }

        function hideConfirm(id) {
            document.getElementById('confirm-' + id).classList.add('d-none');

            // Réafficher le bouton poubelle
            document.querySelectorAll('.btn-outline-danger').forEach(b => b.classList.remove('d-none'));
        }
    </script>
}       