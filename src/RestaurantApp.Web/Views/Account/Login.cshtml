@model RestaurantApp.Web.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Connexion"; Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-card">
    <div class="auth-logo">
        <div class="auth-logo-icon">🍽</div>
    </div>
    <div class="auth-header">
        <h2>Bon retour !</h2>
        <p>Connectez-vous à votre compte</p>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="auth-alert">
            <span>⚠</span>
            <div asp-validation-summary="All"></div>
        </div>
    }

    <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">

        <div class="form-group">
            <label asp-for="Email">Email</label>
            <div class="input-wrap">
                <span class="input-icon">✉</span>
                <input asp-for="Email" class="form-input" placeholder="votre@email.com" autocomplete="email" />
            </div>
            <span asp-validation-for="Email" class="field-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Password">Mot de passe</label>
            <div class="input-wrap">
                <span class="input-icon">🔒</span>
                <input asp-for="Password" type="password" class="form-input" placeholder="••••••" id="pwdInput" />
                <button type="button" class="toggle-pwd" onclick="togglePwd()">👁</button>
            </div>
            <span asp-validation-for="Password" class="field-error"></span>
        </div>

        <div class="remember-row">
            <label class="checkbox-label">
                <input asp-for="RememberMe" type="checkbox" />
                <span>Se souvenir de moi</span>
            </label>
        </div>

        <button type="submit" class="btn-auth btn-primary-auth">
            Se connecter
        </button>
    </form>

    <div class="auth-divider"><span>ou</span></div>

    <p class="auth-switch">
        Pas encore de compte ?
        <a asp-action="Register">Créer un compte</a>
    </p>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function togglePwd() {
            const i = document.getElementById('pwdInput');
            i.type = i.type === 'password' ? 'text' : 'password';
        }
    </script>
}